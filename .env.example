# ─── Database ───────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:@localhost:3306/hamim_db"

# ─── JWT ────────────────────────────────────────
JWT_SECRET="ganti_dengan_string_acak_yang_panjang_dan_aman"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="ganti_dengan_string_lain_untuk_refresh"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── Google OAuth ────────────────────────────────
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"

# ─── Email (SMTP) — dipakai untuk kirim email reset password ───
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"
EMAIL_FROM="HAMIM <no-reply@hamim.app>"

# URL frontend/app yang menampilkan form reset password.
# Token akan ditempel sebagai query param: {RESET_PASSWORD_URL}?token=xxxx
RESET_PASSWORD_URL="http://localhost:3000/reset-password"

# ─── App ─────────────────────────────────────────
PORT=3000
NODE_ENV="development"
